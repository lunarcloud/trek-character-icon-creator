{
    "name": "@lunarcloud/trek-character-icon-creator",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node src/build-html.js",
        "watch": "node src/watch-html.js",
        "serve": "npm run build && npm run watch & npx serve",
        "eslint-fix": "npx eslint --ignore-path .gitignore --ext .js . --fix",
        "eslint": "npx eslint --ignore-path .gitignore --ext .js .",
        "htmllint": "npm run build && npx linthtml \"index.html\"",
        "csslint": "npx stylelint \"**/*.css\" --quiet-deprecation-warnings",
        "csslint-fix": "npx stylelint \"**/*.css\" --quiet-deprecation-warnings --fix",
        "svglint": "npx svglint --ci ./*.svg ./svg/*/*.svg ./svg/*/*/*.svg",
        "spellcheck": "npx cspell --no-progress",
        "lint": "npm run eslint; npm run htmllint; npm run csslint;  npm run svglint; npm run spellcheck",
        "lint-fix": "npm run eslint-fix; npm run htmllint; npm run csslint-fix; npm run svglint; npm run spellcheck",
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "node --experimental-vm-modules node_modules/.bin/jest",
        "outdated": "npx npm-check-updates",
        "outdated:minor": "npx npm-check-updates --target minor",
        "outdated:patch": "npx npm-check-updates --target patch"
    },
    "jest": {
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    },
    "dependencies": {
        "external-svg-loader": "^1.7.1",
        "html2canvas": "^1.4.1"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.2",
        "@linthtml/linthtml": "^0.10.2",
        "@playwright/test": "^1.59.1",
        "axe-core": "^4.11.2",
        "cspell": "^10.0.0",
        "eslint": "^8.57.1",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-editorconfig": "^4.0.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jsdoc": "^46.10.1",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-promise": "^6.6.0",
        "jest": "^30.3.0",
        "npm-check-updates": "^21.0.3",
        "serve": "^14.2.6",
        "stylelint": "^17.9.0",
        "stylelint-config-standard": "^40.0.0",
        "svglint": "^4.2.1"
    }
}
